generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  password      String
  name          String
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  auditLogs     AuditLog[]
  expenses      Expense[]
  approvals     ExpenseApproval[]
  notifications Notification[]
  reminders     Reminder[]
  switchLogs    RoleSwitchLog[]   @relation("SwitchedToUser")
  adminLogs     RoleSwitchLog[]   @relation("AdminUser")
  visitsCreated SalesmanVisit[]   @relation("VisitCreator")
  roles         Role[]            @relation("RoleToUser")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[] @relation("PermissionToRole")
  users       User[]       @relation("RoleToUser")
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[] @relation("PermissionToRole")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  isTobacco Boolean   @default(false)
  products  Product[]
}

model Unit {
  id           String        @id @default(uuid())
  name         String        @unique
  productUnits ProductUnit[]
}

model ProductUnit {
  id         String  @id @default(uuid())
  productId  String
  unitId     String
  conversion Int     @default(1)
  isBase     Boolean @default(false)
  unit       Unit    @relation(fields: [unitId], references: [id])
  product    Product @relation(fields: [productId], references: [id])

  @@unique([productId, unitId])
}

model Salesman {
  id             String          @id @default(uuid())
  name           String
  phone          String
  email          String?
  distributorId  String
  designation    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deliveringDay  String?
  productHandled String?
  visitingDay    String?
  distributor    Distributor     @relation(fields: [distributorId], references: [id])
  visits         SalesmanVisit[]
  products       Product[]       @relation("SalesmanProducts")
}

model SalesmanVisit {
  id                String      @id @default(uuid())
  visitDate         DateTime    @default(now())
  distributorId     String
  salesmanId        String
  purpose           String
  productsDiscussed String?
  offersProvided    String?
  orderPlaced       Boolean     @default(false)
  followUpDate      DateTime?
  notes             String?
  status            String      @default("COMPLETED")
  userId            String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  createdBy         User        @relation("VisitCreator", fields: [userId], references: [id])
  salesman          Salesman    @relation(fields: [salesmanId], references: [id])
  distributor       Distributor @relation(fields: [distributorId], references: [id])
}

model Product {
  id            String                 @id @default(uuid())
  name          String
  categoryId    String
  sku           String?                @unique
  barcode       String?                @unique
  shortCode     String?
  gstPercent    Float                  @default(0)
  hsn           String?
  stock         Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  inventory     InventoryTransaction[]
  invoiceItems  InvoiceItem[]
  category      Category               @relation(fields: [categoryId], references: [id])
  prices        ProductPrice[]
  units         ProductUnit[]
  purchaseItems PurchaseItem[]
  salesmen      Salesman[]             @relation("SalesmanProducts")
  distributors  Distributor[]          @relation("DistributorProducts")
  freeGifts     FreeGift[]             @relation("FreeGifts")
}

model ProductPrice {
  id          String  @id @default(uuid())
  productId   String
  billingType String
  price       Float
  product     Product @relation(fields: [productId], references: [id])

  @@unique([productId, billingType])
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  type      String
  note      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model ExpenseCategory {
  id       String    @id @default(uuid())
  name     String    @unique
  expenses Expense[]
}

model Expense {
  id            String            @id @default(uuid())
  title         String
  date          DateTime          @default(now())
  categoryId    String
  amount        Float
  paymentMode   String
  description   String?
  attachmentUrl String?
  status        String            @default("PENDING")
  userId        String
  createdAt     DateTime          @default(now())
  createdBy     User              @relation(fields: [userId], references: [id])
  category      ExpenseCategory   @relation(fields: [categoryId], references: [id])
  approvals     ExpenseApproval[]
}

model ExpenseApproval {
  id        String   @id @default(uuid())
  expenseId String
  adminId   String
  status    String
  note      String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
  expense   Expense  @relation(fields: [expenseId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model RoleSwitchLog {
  id               String   @id @default(uuid())
  adminUserId      String
  switchedToUserId String
  createdAt        DateTime @default(now())
  switchedToUser   User     @relation("SwitchedToUser", fields: [switchedToUserId], references: [id])
  adminUser        User     @relation("AdminUser", fields: [adminUserId], references: [id])
}

model Customer {
  id                  String               @id @default(uuid())
  name                String
  phone               String?
  email               String?
  type                String
  address             String?
  gstNumber           String?
  creditLimit         Float?               @default(0)
  outstandingBalance  Float                @default(0)
  isActive            Boolean              @default(true)
  notes               String?
  region              String?
  salesmanId          String?
  businessName        String?
  openingBalance      Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  invoices            Invoice[]
  ledgerEntries       CustomerLedger[]
  auditLogs           CustomerAuditLog[]
  giftAllocations     GiftAllocationLog[]  @relation("CustomerGiftAllocations")
}

model CustomerLedger {
  id          String   @id @default(uuid())
  customerId  String
  date        DateTime @default(now())
  description String
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float
  paymentMode String?
  referenceId String?  // Optional link to Invoice or Payment record
  customer    Customer @relation(fields: [customerId], references: [id])
}

model CustomerAuditLog {
  id         String   @id @default(uuid())
  customerId String
  action     String
  oldValue   String?
  newValue   String?
  changedBy  String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Invoice {
  id             String          @id @default(uuid())
  customerId     String?
  billingType    String          @default("RETAIL")
  totalAmount    Float
  gstAmount      Float
  discount       Float           @default(0)
  couponDiscount Float           @default(0)
  netAmount      Float
  profit         Float           @default(0)
  eligibleAmount Float           @default(0)
  paymentMode    String
  paymentStatus  String
  createdAt      DateTime        @default(now())
  customer       Customer?       @relation(fields: [customerId], references: [id])
  items          InvoiceItem[]
  appliedCoupons InvoiceCoupon[]
  generatedCoupons Coupon[]      @relation("GeneratedByInvoice")
  giftAllocations GiftAllocationLog[] @relation("InvoiceGiftAllocation")
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  productId String
  unit      String
  quantity  Int
  price     Float
  total     Float
  profit    Float   @default(0)
  product   Product @relation(fields: [productId], references: [id])
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
}

model Coupon {
  id                String          @id @default(uuid())
  code              String          @unique
  customerId        String
  issueDate         DateTime        @default(now())
  expiryDate        DateTime
  discountType      String          @default("PERCENTAGE")
  discountValue     Float           @default(1)
  discountCap       Float           @default(50)
  minEligibleAmount Float           @default(2000)
  excludedCategory  String?         @default("Tobacco")
  isActive          Boolean         @default(true)
  usedCount         Int             @default(0)
  usageLimit        Int             @default(1)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  referenceInvoiceId String?
  referenceInvoice   Invoice?        @relation("GeneratedByInvoice", fields: [referenceInvoiceId], references: [id])
  appliedInvoices   InvoiceCoupon[]
}

model InvoiceCoupon {
  id        String   @id @default(uuid())
  invoiceId String
  couponId  String
  amount    Float
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  coupon    Coupon   @relation(fields: [couponId], references: [id])

  @@unique([invoiceId, couponId])
}

model SystemConfig {
  id              String   @id @default(uuid())
  businessName    String   @default("Smart Stock")
  address         String?
  phone           String?
  email           String?
  taxId           String?
  currency        String   @default("USD")
  currencySymbol  String   @default("$")
  logoUrl         String?
  couponEnabled   Boolean  @default(true)
  freeGiftsEnabled Boolean @default(true)
  updatedAt       DateTime @updatedAt
}

model Reminder {
  id          String    @id @default(uuid())
  title       String
  description String?
  frequency   String
  isActive    Boolean   @default(true)
  nextRun     DateTime
  lastRun     DateTime?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Distributor {
  id                 String              @id @default(uuid())
  name               String
  contactPerson      String?
  phone              String?
  email              String?
  address            String?
  gstNumber          String?
  notes              String?
  type               String?
  isActive           Boolean             @default(true)
  creditLimit        Float?
  outstandingBalance Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ledgerEntries      DistributorLedger[]
  purchases          Purchase[]
  salesmen           Salesman[]
  products           Product[]           @relation("DistributorProducts")
  visits             SalesmanVisit[]
}

model Purchase {
  id            String            @id @default(uuid())
  invoiceNumber String?
  purchaseDate  DateTime          @default(now())
  distributorId String
  salesmanId    String?
  type          String
  status        String            @default("PENDING")
  totalAmount   Float
  paidAmount    Float             @default(0)
  pendingAmount Float
  paymentMode   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  distributor   Distributor       @relation(fields: [distributorId], references: [id])
  items         PurchaseItem[]
  payments      PurchasePayment[]
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchaseId    String
  productId     String
  unitId        String
  quantity      Int
  purchasePrice Float
  gstPercent    Float    @default(0)
  discount      Float    @default(0)
  totalAmount   Float
  product       Product  @relation(fields: [productId], references: [id])
  purchase      Purchase @relation(fields: [purchaseId], references: [id])
}

model PurchasePayment {
  id          String   @id @default(uuid())
  purchaseId  String
  amount      Float
  paymentDate DateTime @default(now())
  paymentMode String
  note        String?
  purchase    Purchase @relation(fields: [purchaseId], references: [id])
}

model DistributorLedger {
  id            String      @id @default(uuid())
  distributorId String
  date          DateTime    @default(now())
  description   String
  debit         Float       @default(0)
  credit        Float       @default(0)
  balance       Float
  distributor   Distributor @relation(fields: [distributorId], references: [id])
}

model RewardSettings {
  id                    String   @id @default(uuid())
  mode                  String   @default("NONE") // NONE, DISCOUNT, GIFT
  enabled               Boolean  @default(false)
  minEligibleAmount     Float    @default(0)
  excludedCategoryIds   String?  // JSON array of category IDs to exclude from eligible amount
  discountPercent       Float    @default(1) // Used when mode = DISCOUNT
  discountCap           Float    @default(50) // Max discount per invoice
  allowedPaymentModes   String   @default("CASH,UPI,BANK") // CSV of payment modes
  allowedBillingTypes   String   @default("WHOLESALE,DELIVERY") // CSV of customer types
  allocateOnlyByInventory Boolean @default(true) // If true, only allocate gifts with available stock
  fallbackMode          String   @default("NONE") // What to do if gift allocation fails: NONE, DISCOUNT
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model GiftSlab {
  id             String   @id @default(uuid())
  minAmount      Float
  maxAmount      Float
  maxGiftValue   Float    // Max value of gifts that can be allocated in this slab
  priority       Int      @default(1)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([minAmount, maxAmount])
}

model FreeGift {
  id          String   @id @default(uuid())
  productId   String
  giftValue   Float    // Value/weight for allocation algorithm
  stockLimit  Int      @default(0) // 0 = unlimited
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, DISCONTINUED
  priority    Int      @default(1) // Higher priority = picked first
  validFrom   DateTime @default(now())
  validTo     DateTime?
  product     Product  @relation("FreeGifts", fields: [productId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GiftAllocationLog {
  id            String   @id @default(uuid())
  invoiceId     String
  customerId    String
  totalGiftValue Float
  allocations   String   // JSON: [{ giftId, productId, quantity, value }, ...]
  notes         String?
  createdBy     String   // userId
  invoice       Invoice  @relation("InvoiceGiftAllocation", fields: [invoiceId], references: [id])
  customer      Customer @relation("CustomerGiftAllocations", fields: [customerId], references: [id])
  createdAt     DateTime @default(now())
}
